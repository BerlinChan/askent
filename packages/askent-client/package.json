{
  "name": "askent-client",
  "version": "0.1.0",
  "license": "MIT",
  "description": "A simple presentation tool",
  "repository": {
    "type": "git",
    "url": "https://github.com/BerlinChan/askent.git",
    "directory": "packages/askent-client"
  },
  "homepage": "https://askent.berlinchan.com/",
  "scripts": {
    "start": "vite --host 0.0.0.0",
    "build": "tsc --noEmit && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview --host 0.0.0.0",
    "cypress:open": "cypress open",
    "codegen": "env-cmd -f ../askent-server/.env ts-node --skip-project tools/codegen.ts",
    "intl:extract": "formatjs extract 'src/**/*.tsx' --out-file lang/en.json --id-interpolation-pattern '[sha512:contenthash:base64:6]'",
    "intl:compile": "formatjs compile-folder lang src/generated/lang"
  },
  "dependencies": {
    "@apollo/client": "3.5.10",
    "@date-io/date-fns": "2.17.0",
    "@fingerprintjs/fingerprintjs": "3.3.2",
    "@mui/icons-material": "5.5.1",
    "@mui/lab": "5.0.0-alpha.75",
    "@mui/material": "5.5.1",
    "@mui/styles": "5.5.1",
    "@mui/system": "5.5.1",
    "@mui/utils": "5.5.3",
    "@emotion/react": "11.8.2",
    "@emotion/styled": "11.8.1",
    "askent-common": "file:../askent-common",
    "copy-to-clipboard": "3.3.1",
    "date-fns": "2.23.0",
    "formik": "2.2.9",
    "formik-material-ui": "3.0.1",
    "formik-material-ui-pickers": "0.0.12",
    "graphql": "16.2.0",
    "graphql-tag": "2.12.6",
    "material-ui-popup-state": "5.3.7",
    "notistack": "2.0.8",
    "qrcode.react": "4.1.0",
    "ramda": "0.28.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-intl": "5.24.4",
    "react-router-dom": "6.2.1",
    "react-virtuoso": "2.4.1",
    "screenfull": "6.0.1",
    "subscriptions-transport-ws": "0.11.0",
    "yup": "0.32.11"
  },
  "devDependencies": {
    "@cypress/react": "5.12.4",
    "@cypress/webpack-dev-server": "1.8.0",
    "@formatjs/cli": "4.8.1",
    "@graphql-codegen/cli": "2.4.0",
    "@graphql-codegen/typescript-operations": "2.2.3",
    "@graphql-codegen/typescript-react-apollo": "3.2.4",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/jest": "27.4.0",
    "@types/node": "16.11.21",
    "@types/qrcode.react": "1.0.2",
    "@types/react": "17.0.38",
    "@types/react-dom": "17.0.11",
    "@types/yup": "0.29.13",
    "@vitejs/plugin-react": "6.0.2",
    "cypress": "9.4.1",
    "jsdom": "29.1.1",
    "typescript": "5.9.3",
    "vite": "8.0.16",
    "vitest": "4.1.8"
  },
  "eslintConfig": {
    "extends": "react-app"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
